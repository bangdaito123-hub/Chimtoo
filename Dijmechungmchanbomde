-- ==================== FIX LAG THEO CẤP 1-5 ====================
local LagFix = {}
LagFix.RemoveFog = function()
    S.L.FogEnd = 100000; S.L.FogStart = 100000; S.L.FogColor = Color3.new(0,0,0)
    pcall(function() S.L.Atmosphere:Destroy() end)
end
LagFix.RemoveShadows = function()
    for _, v in pairs(S.W:GetDescendants()) do
        if v:IsA("Shadow") or v:IsA("SpotLight") or v:IsA("PointLight") then v.Enabled = false end
    end
    S.L.GlobalShadows = false; S.L.ClockTime = 12; S.L.Brightness = 2
end
LagFix.SetMaxView = function()
    S.W.CurrentCamera.MaxExtentsIntensity = math.huge
    pcall(function() settings().Rendering.QualityLevel = 1; settings().Rendering.AutoFRMLevel = 0 end)
end
LagFix.ReduceEffects = function(level)
    local effects = {"ParticleEmitter","Trail","Beam","Smoke","Fire","Sparkles","Decal"}
    for _, obj in pairs(S.W:GetDescendants()) do
        for _, e in pairs(effects) do
            if obj:IsA(e) then
                if level == 1 then pcall(function() obj.Rate = obj.Rate * 0.3; obj.Lifetime = NumberRange.new(0.1) end)
                elseif level == 2 then pcall(function() obj.Enabled = false end)
                elseif level >= 3 then pcall(function() obj:Destroy() end) end
            end
        end
    end
    if level >= 3 then
        for _, v in pairs(S.W:GetDescendants()) do
            if v.Name:lower():find("effect") or v.Name:lower():find("skill") then v:Destroy() end
        end
    end
    if level >= 4 then
        for _, part in pairs(S.W:GetDescendants()) do
            if part:IsA("BasePart") and part.Material ~= Enum.Material.Air then
                part.Color = Color3.fromRGB(128,128,128); part.Material = Enum.Material.SmoothPlastic
            end
        end
        pcall(function() S.L.ColorCorrection.Enabled = false end)
    end
    if level >= 5 then
        for _, player in pairs(S.P:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                for _, part in pairs(player.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.Size = Vector3.new(1.5,1.5,1.5); part.Shape = Enum.PartType.Ball
                    end
                end
            end
        end
        for _, v in pairs(S.W:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then v:Destroy() end
        end
    end
end
LagFix.Apply = function(level)
    level = math.clamp(level, 1, 5)
    Settings.LagFixLevel = level
    LagFix.RemoveFog(); LagFix.RemoveShadows(); LagFix.SetMaxView(); LagFix.ReduceEffects(level)
end

