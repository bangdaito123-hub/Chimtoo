local hopLowerPlayerButton = TabMisc:CreateButton({
    Name = "Hop To Lower Player",
    Callback = function()
        getgenv().AutoTeleport = true
        getgenv().DontTeleportTheSameNumber = true
        getgenv().CopytoClipboard = false
        local lowestPlayers = math.huge
        local lowestId
        local function fetchServers()
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
            local data = HttpService:JSONDecode(game:HttpGet(url))
            for _, server in pairs(data.data) do
                if server.playing < lowestPlayers then
                    lowestPlayers = server.playing
                    lowestId = server.id
                end
            end
            if data.nextPageCursor then
                fetchServers(data.nextPageCursor)
            end
        end
        fetchServers()
        if lowestId then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, lowestId)
        else
            TeleportService:Teleport(game.PlaceId)
        end
    end
})
