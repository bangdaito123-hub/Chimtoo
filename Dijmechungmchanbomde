-- ==================== FIX LAG SCRIPT (MoonVeil deobfuscated) ====================
local fixLagSettings = {
    enabled = false,
    fpsBoost = true,
    removeFog = true,
    removeGrass = true,
    lowGraphics = true,
    disableShadows = true,
    antiLag = true,
    maxFPS = 60
}
local function fixLag()
    if not fixLagSettings.enabled then return end
    if fixLagSettings.fpsBoost then
        RunService.RenderStepped:Wait()
    end
    if fixLagSettings.removeFog then
        Lighting.FogEnd = 100000
        Lighting.FogStart = 100000
    end
    if fixLagSettings.removeGrass then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("Terrain") then
                v.WaterWaveSize = 0
                v.WaterWaveSpeed = 0
                v.WaterReflectance = 0
                v.WaterTransparency = 0
            end
        end
    end
    if fixLagSettings.lowGraphics then
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.FogStart = 100000
    end
    if fixLagSettings.disableShadows then
        Lighting.Shadows = false
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("Part") or v:IsA("MeshPart") then
                v.Material = Enum.Material.Plastic
            end
        end
    end
    if fixLagSettings.antiLag then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            end
        end
    end
end

