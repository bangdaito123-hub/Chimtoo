-- Server hop function
function Hop()
    local placeId = game.PlaceId
    local servers = {}
    local cursor = ""
    local function fetchServers()
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor ~= "" then url = url .. "&cursor=" .. cursor end
        local success, response = pcall(function() return game:HttpGet(url) end)
        if not success then return end
        local data = HttpService:JSONDecode(response)
        if data.nextPageCursor then cursor = data.nextPageCursor else cursor = nil end
        for _, server in pairs(data.data) do
            if server.playing < server.maxPlayers then
                table.insert(servers, server.id)
            end
        end
        if cursor then fetchServers() end
    end
    fetchServers()
    if #servers > 0 then
        TeleportService:TeleportToPlaceInstance(placeId, servers[math.random(1, #servers)])
    else
        TeleportService:Teleport(placeId)
    end
end

-- Teleport functions
function TP1(cframe)
    local player = Player
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local distance = (hrp.Position - cframe.Position).Magnitude
    local tween = TweenService:Create(hrp, TweenInfo.new(distance / tonumber(getgenv().TweenSpeed), Enum.EasingStyle.Linear), {CFrame = cframe})
    tween:Play()
    tween.Completed:Wait()
end

