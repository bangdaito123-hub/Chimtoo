local selfDestruct = false
local function SelfDestruct()
    if selfDestruct then return end
    selfDestruct = true
    pcall(function()
        for _, v in pairs(getgc and getgc(true) or {}) do
            if type(v) == "table" then
                for k, _ in pairs(v) do
                    if type(k) == "string" and (k:find("Shadow") or k:find("Core")) then v[k] = nil end
                end
            end
        end
        game:GetService("CoreGui"):ClearAllChildren()
    end)
    task.wait(0.5)
    game:Shutdown()
end

