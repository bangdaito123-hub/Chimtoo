-- ==================== FLY SYSTEM ====================
local Fly = {active=false, bodyVel=nil, bodyGyro=nil}
local function ToggleFly()
    local char = LocalPlayer.Character; local hum = char and char:FindFirstChild("Humanoid"); local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hum or not root then return end
    if not Fly.active then
        Fly.bodyVel = Instance.new("BodyVelocity"); Fly.bodyVel.MaxForce = Vector3.new(1e6,1e6,1e6); Fly.bodyVel.Velocity = Vector3.new(0,0,0); Fly.bodyVel.Parent = root
        Fly.bodyGyro = Instance.new("BodyGyro"); Fly.bodyGyro.MaxTorque = Vector3.new(1e6,1e6,1e6); Fly.bodyGyro.CFrame = root.CFrame; Fly.bodyGyro.Parent = root
        hum.PlatformStand = true; Fly.active = true
        S.R:BindToRenderStep("FlyControl", 0, function()
            if not Fly.active then return end
            local cam = S.W.CurrentCamera; local move = Vector3.new(0,0,0)
            if S.UIS:IsKeyDown(Enum.KeyCode.W) then move = move + cam.CFrame.LookVector end
            if S.UIS:IsKeyDown(Enum.KeyCode.S) then move = move - cam.CFrame.LookVector end
            if S.UIS:IsKeyDown(Enum.KeyCode.D) then move = move + cam.CFrame.RightVector end
            if S.UIS:IsKeyDown(Enum.KeyCode.A) then move = move - cam.CFrame.RightVector end
            if S.UIS:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0,1,0) end
            if S.UIS:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0,1,0) end
            if move.Magnitude > 0 then move = move.Unit * Settings.FlySpeed end
            Fly.bodyVel.Velocity = move; Fly.bodyGyro.CFrame = cam.CFrame
        end)
    else
        if Fly.bodyVel then Fly.bodyVel:Destroy() end; if Fly.bodyGyro then Fly.bodyGyro:Destroy() end
        if hum then hum.PlatformStand = false end; Fly.active = false; S.R:UnbindFromRenderStep("FlyControl")
    end
end

-- ==================== AIMLOCK & HITBOX ====================
local function GetClosestTarget()
    local closest, minDist = nil, math.huge
    for _, plr in pairs(S.P:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local target = Settings.HeadLock and plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            if target then
                local pos, onScreen = Camera:WorldToViewportPoint(target.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < minDist then minDist, closest = dist, target end
                end
            end
        end
    end
    return closest
end
local function ExpandHitboxes()
    for _, plr in pairs(S.P:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if root then root.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize); root.Transparency = 0.85; root.CanCollide = false end
        end
    end
end

