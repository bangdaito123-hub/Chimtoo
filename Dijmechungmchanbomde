-- HÀM RAYCAST WALLCHECK
local function IsVisible(targetPart)
    if not V4.WallCheck then return true end
    local hit = workspace:FindPartOnRayWithIgnoreList(Ray.new(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 1000), {LP.Character, Camera})
    return hit and hit:IsDescendantOf(targetPart.Parent)
end

-- [ GỘP LOOP 1: RENDER STEPPED DÀNH CHO AIMBOT/ESP/VISUALS ] --
Services.RunService.RenderStepped:Connect(function()
    -- 1. FOV
    FOVCircle.Visible = V4.ShowFOV
    FOVCircle.Radius = V4.FOVSize
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    local aimTarget, closest = nil, V4.FOVSize

    -- 2. Duyệt qua Players
    for _, p in ipairs(Services.Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local root = p.Character.HumanoidRootPart
            local head = p.Character:FindFirstChild("Head")
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            -- Aimbot Logic
            if V4.Aimbot and onScreen and head then
                if not (V4.TeamCheck and p.Team == LP.Team) then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < closest and IsVisible(head) then closest = dist; aimTarget = head end
                end
            end

            -- Quản lý ESP Cache
            if not ESP_Cache[p] then 
                ESP_Cache[p] = { text = Drawing.new("Text"), hl = Instance.new("Highlight") } 
                ESP_Cache[p].text.Size = 16; ESP_Cache[p].text.Center = true; ESP_Cache[p].text.Outline = true; ESP_Cache[p].text.Color = Color3.new(1,1,1)
            end
            
            local esp = ESP_Cache[p]
            -- Highlight
            esp.hl.Parent = V4.ESP_Highlight and p.Character or nil
            if V4.ESP_Highlight then esp.hl.FillColor = Color3.new(1,0,0); esp.hl.OutlineColor = Color3.new(1,1,1) end
            
            -- Name ESP
            if V4.ESP_Name and onScreen then
                esp.text.Visible = true
                esp.text.Position = Vector2.new(pos.X, pos.Y - 40)
                esp.text.Text = p.Name .. " [" .. math.floor((LP.Character.HumanoidRootPart.Position - root.Position).Magnitude) .. "m]"
            else esp.text.Visible = false end
        else
            if ESP_Cache[p] then ESP_Cache[p].text.Visible = false; ESP_Cache[p].hl.Parent = nil end
        end
    end

    -- 3. Aimbot Lock
    if aimTarget then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, aimTarget.Position), V4.Smooth) end
end)

-- Xóa Cache khi Player thoát
Services.Players.PlayerRemoving:Connect(function(p) if ESP_Cache[p] then ESP_Cache[p].text:Remove(); ESP_Cache[p].hl:Destroy(); ESP_Cache[p] = nil end end)

-- [ GỘP LOOP 2: STEPPED DÀNH CHO MOVEMENT VÀ VẬT LÝ ] --
Services.RunService.Stepped:Connect(function()
    pcall(function()
        if not LP.Character then return end
        
        -- Walkspeed / JumpPower
        local hum = LP.Character:FindFirstChild("Humanoid")
        if hum then 
            hum.WalkSpeed = V4.WalkSpeed
            hum.JumpPower = V4.JumpPower
            if V4.JumpPower ~= 50 then hum.UseJumpPower = true end
        end
        
        -- Noclip
        if V4.Noclip then for _,v in ipairs(LP.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end
        
        -- Anti-Fling
        if V4.AntiFling then
            for _, p in ipairs(Services.Players:GetPlayers()) do
                if p ~= LP and p.Character then for _, v in ipairs(p.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end
            end
        end

        -- Fly Logic (BodyVelocity)
        local root = LP.Character:FindFirstChild("HumanoidRootPart")
        if V4.Fly and root then
            local bv = root:FindFirstChild("V4_BV") or Instance.new("BodyVelocity", root); bv.Name = "V4_BV"; bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
            local bg = root:FindFirstChild("V4_BG") or Instance.new("BodyGyro", root); bg.Name = "V4_BG"; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bg.cframe = Camera.CFrame
            local dir = Vector3.zero
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
            if Services.UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
            bv.velocity = dir * V4.FlySpeed
        else
            if root then
                if root:FindFirstChild("V4_BV") then root.V4_BV:Destroy() end
                if root:FindFirstChild("V4_BG") then root.V4_BG:Destroy() end
            end
        end
    end)
end)

