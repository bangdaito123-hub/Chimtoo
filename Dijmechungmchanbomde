local function IsOnTeam(player)
    if not getgenv().TeamCheck then return false end
    return player.Team == LP.Team
end

local function GetClosestPlayer()
    local target = nil
    local dist = getgenv().FOVSize
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild(getgenv().AimPart) and not IsOnTeam(v) then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character[getgenv().AimPart].Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then
                    dist = mag
                    target = v
                end
            end
        end
    end
    return target
end

