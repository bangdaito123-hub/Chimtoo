    FOVCircle.Visible = getgenv().ShowFOV
    if getgenv().Aimbot then
        local target = GetClosestPlayer()
        if target then
            local targetPos = Camera:WorldToViewportPoint(target.Character[getgenv().AimPart].Position)
            mousemoverel((targetPos.X - Camera.ViewportSize.X/2) * getgenv().Smoothness, (targetPos.Y - Camera.ViewportSize.Y/2) * getgenv().Smoothness)
        end
    end
end)

local function ApplyESP(player)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_H"
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = player.Character
    
    local nameTag = Instance.new("BillboardGui")
    nameTag.Name = "ESP_N"
    nameTag.Size = UDim2.new(0, 200, 0, 50)
    nameTag.Adornee = player.Character:WaitForChild("Head")
    nameTag.AlwaysOnTop = true
    local label = Instance.new("TextLabel", nameTag)
    label.Text = player.Name
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    nameTag.Parent = player.Character
end

