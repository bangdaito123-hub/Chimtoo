    local function addBtn(text, y, col, cb)
        local btn = Instance.new("TextButton"); btn.Size = UDim2.new(0.9,0,0,35); btn.Position = UDim2.new(0.05,0,0,y)
        btn.Text = text; btn.TextColor3 = Color3.new(1,1,1); btn.BackgroundColor3 = col; btn.BorderSizePixel = 1; btn.Font = Enum.Font.Gotham; btn.TextSize = 13; btn.Parent = main
        btn.MouseButton1Click:Connect(cb); return btn
    end
    local function addSlider(text, y, minV, maxV, step, default, callback)
        local frame = Instance.new("Frame"); frame.Size = UDim2.new(0.9,0,0,55); frame.Position = UDim2.new(0.05,0,0,y)
        frame.BackgroundColor3 = Color3.new(30,30,30); frame.BackgroundTransparency = 0.5; frame.Parent = main
        local label = Instance.new("TextLabel"); label.Size = UDim2.new(1,0,0,20); label.Text = text .. ": " .. default; label.TextColor3 = Color3.new(1,1,1); label.BackgroundTransparency = 1; label.Font = Enum.Font.Gotham; label.TextSize = 12; label.Parent = frame
        local slider = Instance.new("TextButton"); slider.Size = UDim2.new(1,0,0,25); slider.Position = UDim2.new(0,0,0,22); slider.Text = ""; slider.BackgroundColor3 = Color3.new(100,100,100); slider.BorderSizePixel = 1; slider.Parent = frame
        local fill = Instance.new("Frame"); fill.Size = UDim2.new((default-minV)/(maxV-minV),0,1,0); fill.BackgroundColor3 = Color3.new(1,0,0); fill.BorderSizePixel = 0; fill.Parent = slider
        local val = default; local drag = false
        local function update()
            fill.Size = UDim2.new((val-minV)/(maxV-minV),0,1,0); label.Text = text .. ": " .. string.format("%.1f", val); callback(val)
        end
        slider.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
        slider.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
        slider.MouseMoved:Connect(function()
            if drag then
                local mx = S.UIS:GetMouseLocation().X; local sx = slider.AbsolutePosition.X; local sw = slider.AbsoluteSize.X
                local ratio = math.clamp((mx - sx) / sw, 0, 1); val = minV + ratio * (maxV - minV); val = math.floor(val / step) * step; update()
            end
        end)
        update()
        return {set=function(v) val = v; update() end}
    end

    -- Fix Lag cấp 1-5
    addBtn("🔧 CẤP 1 (Giảm hiệu ứng)", 40, Color3.new(0,0.3,0), function() LagFix.Apply(1) end)
    addBtn("🔧 CẤP 2 (Xóa hiệu ứng mạnh)", 80, Color3.new(0,0.4,0), function() LagFix.Apply(2) end)
