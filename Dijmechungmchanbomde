-- ==================== LỚP BẢO MẬT & TỰ HỦY ====================
local function decryptLayer1(data)
    local decrypted = ""
    for i = 1, #data do decrypted = decrypted .. string.char(string.byte(data, i) ~ (i % 255)) end
    return decrypted
end
local function decryptLayer2(encrypted)
    local reversed = string.reverse(encrypted)
    local final = ""
    for i = 1, #reversed do
        local char = string.sub(reversed, i, i)
        if char == "X" then final = final .. "A" elseif char == "Y" then final = final .. "B" elseif char == "Z" then final = final .. "C" else final = final .. char end
    end
    return final
end
