local function getService(serviceName)
    local hash = 0
    for i = 1, #serviceName do hash = (hash + string.byte(serviceName, i)) % 65536 end
    local tbl = {
        [30457] = game:GetService("Players"), [29102] = game:GetService("RunService"),
        [27891] = game:GetService("ReplicatedStorage"), [31234] = game:GetService("TeleportService"),
        [29876] = game:GetService("HttpService"), [28765] = game:GetService("Lighting"),
        [30123] = game:GetService("Workspace"), [29567] = game:GetService("CoreGui"),
        [30891] = game:GetService("StarterGui"), [32145] = game:GetService("UserInputService"),
        [33456] = game:GetService("Stats"),
    }
    return tbl[hash]
end

